# image-forge 环境变量配置示例
# 复制本文件为 .env 并填入实际值
# 注意：.env 文件已被 .gitignore 排除，请勿提交到 git

# ── GPT Image 2 后端（via CRS 或任意 OpenAI 兼容代理）──
# CRS 服务地址（默认 localhost，生产环境替换为你的 CRS 地址）
CRS_BASE_URL=http://127.0.0.1:8765

# CRS API Key（从你的 CRS 管理后台获取，以 cr_ 开头）
CRS_API_KEY=cr_your_key_here

# 也可以直接使用 OpenAI 官方 API（需同时修改 backends.yaml 里的 endpoint）
# OPENAI_API_KEY=sk-your_openai_key_here

# ── Gemini / Nano Banana 2 后端 ──
# Google Gemini API Key（从 https://aistudio.google.com 获取）
GEMINI_API_KEY=your_gemini_key_here

# Nano Banana API Key（备用，generate_image.py 会优先使用 GEMINI_API_KEY）
# NANO_BANANA_API_KEY=your_nano_banana_key_here
